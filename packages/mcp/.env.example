# Penca Ovación MCP server — HTTP transport env.
# Copy to .env (gitignored) and fill in for a deployment.

# Listen port for the Streamable HTTP server (default 3000).
PORT=3000

# Request path for the MCP endpoint (default /mcp).
MCP_PATH=/mcp

# Shared secret that gates who may reach the server. If set, requests must send
# `Authorization: Bearer <secret>` or `?token=<secret>`. Leave blank only for
# local testing — an unset secret means the endpoint is an open Penca proxy.
MCP_BEARER_SECRET=

# Optional override of the Penca API base URL.
PENCA_BASE_URL=

# OpenPanel analytics — server-side, HTTP transport only.
# Leave blank to disable. Stdio runs and any deploy without these vars stay silent.
# Use a dedicated "Penca Ovación MCP" OpenPanel project so tool calls don't
# collide with web/mobile screen views.
OPENPANEL_CLIENT_ID=
OPENPANEL_CLIENT_SECRET=
# Self-hosted OpenPanel instance. The SaaS default (https://api.openpanel.dev)
# will reject self-hosted creds with 401, so point this at your instance.
OPENPANEL_API_URL=https://api.openpanel.dev
# Set to 1 to log every successful send to stderr (verbose). Failures are
# always logged. Outcome counters are exposed at GET /analytics/stats.
OPENPANEL_DEBUG=
