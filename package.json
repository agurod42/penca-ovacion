{
  "name": "penca-ovacion-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Toolkit no oficial para Penca Antel Ovación — SDK tipado, CLI y servidor MCP.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/sdk",
    "packages/cli",
    "packages/mcp"
  ],
  "scripts": {
    "build": "npm run build -w penca-ovacion-sdk && npm run build -w penca-ovacion && npm run build -w @1930dev/penca-ovacion-mcp",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "clean": "rimraf 'packages/*/dist' 'packages/*/*.tsbuildinfo'"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.14.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
